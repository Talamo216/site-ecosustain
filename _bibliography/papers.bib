  doi = {10.1145/3774900.3776638},
  booktitle = {Proceedings of the International Workshop on Middleware
               for IT/OT Integration},
  pages = {25–30},
  numpages = {6},
  location = {Nashville, TN, USA},
  series = {MITOTI '25},
  abstract = {The concept of smart cities entails the use of information
              technologies to access the resources of a city in a more
              intelligent way by providing specialized services to citizens
              and city officials. In this way, the city's IT infrastructure
              should facilitate the development, deployment, and operation
              of smart city applications for diverse application domains.
              Building such applications is challenging since they are used
              on large-scale systems, have dynamic behavior, must access
              heterogeneous resources, and must deal with the semantics
              of different domains. We propose and evaluate an integrated
              approach for the development and execution of smart city
              applications in this context. To this end, we leverage
              a model-driven approach for domain-specific middleware,
              adding support for the development of applications in a
              platform-agnostic way using domain-specific building blocks.
              The proposed approach significantly reduces development
              complexity and enables the effective adaptation of
              domain-specific applications for different smart city
              platforms with adequate performance.},
}

@inproceedings{10.1145/3774898.3778039,
  author = {Borelli, Helberth and Longo, Humberto José and Costa,
            Fábio M. and de Carvalho, Sérgio Teixeira},
  title = {Efficient Service Placement and Node Allocation in
           Fog and Edge Computing},
  year = {2025},
  isbn = {9798400723018},
  publisher = {Association for Computing Machinery},
  address = {New York, NY, USA},
  doi = {10.1145/3774898.3778039},
  booktitle = {Proceedings of the 3rd International Workshop
               on Middleware for the Computing Continuum},
  pages = {13–18},
  numpages = {6},
  location = {Nashville, TN, USA},
  series = {Mid4CC '25},
  abstract = {Service placement and server allocation in fog and edge
              computing environments are challenging, especially for
              latency-sensitive applications, due to the limited
              resources and diverse service demands. This study
              proposes and evaluates three specialized heuristics that
              improve resource utilization while minimizing network
              latency and placement overhead. The heuristics are designed
              to: (i) minimize the number of allocated nodes, (ii) maximize
              resource utilization of active nodes, and (iii) reduce
              communication path lengths. To assess their effectiveness,
              the heuristics are compared against integer linear programming
              (ILP) models used as optimal baselines. The experimental
              results show that the heuristics achieve, on average, nearly
              80\% efficiency relative to their counterpart ILP solutions
              while drastically reducing execution time by several orders
              of magnitude, making them suitable for real-time and
              resource-constrained environments. These findings underscore
              the flexibility of the heuristics, offering a practical
              trade-off between solution quality and processing time in
              fog and edge computing scenarios.},
}

