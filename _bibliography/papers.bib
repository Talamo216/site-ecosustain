@article{Abelém_2026,
  title={A Revolução das Tecnologias Quânticas: Caminhos para o Desenvolvimento Nacional},
  doi={10.5753/compbr.2026.55.7501},
  number={55},
  journal={Computação Brasil},
  author={Abelém, Antônio},
  year={2026},
  month=jan,
  pages={23–27},
  abstract={As tecnologias quânticas representam uma fronteira científica estratégica com potencial para transformar sistemas de comunicação, computação, segurança e sensoriamento. Avançar nesse campo no Brasil exige superar desafios estruturais relacionados ao desenvolvimento de hardware, à criação de algoritmos e ferramentas de software quântico, à construção de redes quânticas interoperáveis e ao fortalecimento da segurança resistente a ataques quânticos. Além disso, a formação de profissionais especializados permanece como um dos fatores mais críticos para consolidar o ecossistema nacional. Este artigo apresenta uma visão integrada desses desafios e discute caminhos para fortalecer a soberania tecnológica do Brasil e ampliar sua participação na economia quântica emergente.},
}

