---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">{{ page.title }}</h1>
    <p class="post-description">{{ page.description }}</p>
  </header>

  {%- for software in site.data.softwares -%}

    <article style="margin-top: 5ex">

      <h2 style="margin-bottom: 1ex">
        <strong style="color: #885555">{{software.name}}</strong></h2>

      {% if software.logo != blank %}

        {%- capture theimage -%}
          <img src="/assets/img/{{software.logo}}" alt="{{software.alt}}"
               style="height: 4ex; float: left; margin-top: .8ex;
                      margin-bottom: .8ex; margin-right: 2em; max-width: 20%">
        {%- endcapture -%}

        {%- if software.url == blank %}
          {{theimage}}{%- else -%}<a href="{{software.url}}">{{theimage}}</a>
        {%- endif -%}

      {%- endif -%}

      <div style="width: 60%;">{{software.desc}}</div>

      {%- if software.homepage != blank %}
        <div style="display: flex; justify-content: flex-start; width: 60%;
                    align-items: baseline; gap: 9px; margin-top: 2ex">
          <div style="min-width: 5.5em; text-align: right"><strong>Homepage:</strong></div>
          <div><a href="{{software.homepage}}">{{software.homepage}}</a></div>
        </div>
      {%- endif %}

      {%- if software.url != blank %}
        <div style="display: flex; justify-content: flex-start; width: 60%;
                    align-items: baseline; gap: 9px; margin-top: 2ex">
          <div style="min-width: 5.5em; text-align: right"><strong>Repository:</strong></div>
          <div><a href="{{software.url}}">{{software.url}}</a></div>
        </div>
      {%- endif %}

      {%- if software.paper_url != blank %}
        <div style="display: flex; justify-content: flex-start; width: 60%;
                    align-items: baseline; gap: 9px; margin-top: 2ex">
          <div style="min-width: 5.5em; text-align: right"><strong>Paper:</strong></div>
          <div><a href="{{software.paper_url}}">{{software.paper_title}}</a></div>
        </div>
      {%- endif %}

    </article>
  {%- endfor %}
</div>
